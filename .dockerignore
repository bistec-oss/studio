# Dependencies — reinstalled inside the image (Windows-native node_modules
# must never be baked into a Linux image layer).
node_modules
**/node_modules

# Next.js build output — rebuilt inside the image.
.next
**/.next

# Version control
.git
.gitignore

# Environment files — never bake real secrets into image layers.
.env
.env.*
!.env.example

# Test artifacts / test suite — not needed for the production build.
playwright-report
test-results
tests

# TypeScript incremental build info
tsconfig.tsbuildinfo
*.tsbuildinfo

# Editor / agent / planning tooling — irrelevant to the build
.claude
.specclaw
.husky
.vscode
.idea

# Docs — irrelevant to the build (prisma/, src/, public/, package files kept)
docs
*.md

# Misc
.DS_Store
npm-debug.log*
yarn-debug.log*
.vercel
