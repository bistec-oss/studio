{
  "name": "bistec-studio",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.6"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "prepare": "husky install",
    "mcp": "tsx src/mcp/server.ts",
    "db:seed": "node --env-file=.env scripts/seed-admin.mjs && node --env-file=.env scripts/seed-brandkit.mjs && node --env-file=.env scripts/seed-hearts-talk.mjs",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:mock": "cross-env TEST_BASE_URL=http://localhost:3001 MOCK_AI=true MOCK_PUPPETEER=true MOCK_SOCIAL=true playwright test",
    "test:e2e:reg": "node --env-file=.env.test ./node_modules/@playwright/test/cli.js test",
    "test:e2e:db": "node scripts/setup-test-db.mjs",
    "test:e2e:serve": "dotenv -e .env.test -- next dev -p 3001"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/s3-request-presigner": "^3.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/client": "^5.0.0",
    "@radix-ui/react-dialog": "^1.1.18",
    "@radix-ui/react-dropdown-menu": "^2.1.21",
    "@tanstack/react-query": "^5.101.2",
    "better-auth": "^1.0.0",
    "lucide-react": "^1.23.0",
    "mammoth": "^1.12.0",
    "next": "^16.2.10",
    "openai": "^4.0.0",
    "p-limit": "^7.3.0",
    "pdf-parse": "^2.4.5",
    "puppeteer-core": "^25.3.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sonner": "^2.0.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.0.0",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.10",
    "husky": "^9.0.0",
    "lint-staged": "^17.0.8",
    "postcss": "^8.0.0",
    "prettier": "^3.0.0",
    "prisma": "^5.0.0",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.19.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.10"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx}": [
      "eslint --fix"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "allowScripts": {
    "@prisma/engines@5.22.0": true,
    "prisma@5.22.0": true
  }
}
