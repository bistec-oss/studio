generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  EDITOR
}

enum DesignMode {
  TEMPLATE
  GENERATE
}

// Output canvas shape. SQUARE = 1080×1080 (1:1), PORTRAIT = 1080×1350 (3:4).
// Pixel dimensions live in src/lib/aspectRatio.ts (single source of truth).
enum AspectRatio {
  SQUARE
  PORTRAIT
  STORY
}

enum DraftStatus {
  IN_PROGRESS
  EXPORTED
  PUBLISHED
  FAILED
}

// A draft action (regenerate/refine) running in the background via the F1
// async pattern. Claimed atomically at request time; cleared when the run
// settles. Distinct from DraftStatus — the draft keeps its content/status
// while an action is in flight.
enum DraftAction {
  REGENERATE_COPY
  REGENERATE_DESIGN
  REFINE
}

enum Channel {
  INSTAGRAM
  LINKEDIN
}

enum PostStatus {
  PENDING
  SCHEDULED
  PUBLISHING
  PUBLISHED
  FAILED
  CANCELLED
}

// Lifecycle of a scheduled post generation (mirrors Post's H12 machinery:
// RUNNING overloads nextRetryAt as the worker lease deadline).
enum GenerationStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

// What happens after a scheduled generation completes: hold the draft for
// human review, auto-create SCHEDULED posts at publishAt, or publish at once.
enum PostGenerationAction {
  HOLD
  SCHEDULE_PUBLISH
  PUBLISH_NOW
}

enum ProviderSlot {
  COPY
  IMAGE
}

// Lifecycle of a user's personal Claude OAuth token (`claude setup-token`).
// INVALID = an auth failure was observed mid-call (expired/revoked); the UI
// prompts the user to reconnect and generation falls back to the shared token.
enum ClaudeTokenStatus {
  ACTIVE
  INVALID
}

enum ArtifactType {
  LOGO
  FONT
  COLOR
  REFERENCE_IMAGE
  REFERENCE_DOC
  EXAMPLE_POST
  OTHER
}

// ── better-auth models ────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  // Sign-in identity (better-auth username plugin): `username` is the
  // lowercase unique handle, `displayUsername` preserves the entered casing.
  // Email is kept internally (better-auth requires it) but is not the login.
  username        String?   @unique
  displayUsername String?
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  // app-level role (managed server-side only — never writable via sign-up)
  role          Role      @default(EDITOR)
  // deactivated accounts keep their content/attribution but cannot log in;
  // toggled only by super-admins via /api/admin/users
  disabled      Boolean   @default(false)
  // better-auth relations
  sessions      Session[]
  accounts      Account[]
  // app relations
  briefs        Brief[]
  posts         Post[]
  scheduledGenerations ScheduledGeneration[]
  claudeToken   UserClaudeToken?
  briefDrafts   BriefDraft[]
}

// An UNFINISHED brief-wizard session (autosaved working state), NOT a Brief:
// a Brief is only ever created at Generate time. The payload is wizard-shaped
// (step index, image intents, template selections) and zod-validated at the
// service layer (src/lib/brief/briefDrafts.ts), which also owns the 5-per-user
// cap and the 7-day lazy TTL sweep. Owner-only — admins cannot read other
// users' unfinished briefs (private working state, unlike generated drafts).
model BriefDraft {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic     String   @default("") // denormalized from payload for dashboard rows
  payload   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, updatedAt])
}

// A user's personal Claude Code OAuth token (pasted from `claude setup-token`).
// Used by CLI-mode generation (`claude -p`) so calls bill the user's own Claude
// subscription; absent/INVALID rows fall back to the shared server token.
// Separate 1:1 model (not fields on User) so the ciphertext never rides along
// in the widely-selected better-auth User rows. Mirrors the AvailableProvider
// secret pattern: AES-256-GCM ciphertext + a display-only masked suffix.
model UserClaudeToken {
  id              String            @id @default(cuid())
  userId          String            @unique
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  encryptedToken  String // AES-256-GCM via src/lib/crypto.ts — never returned to clients
  keyPrefix       String // display-only masked suffix `…${token.slice(-4)}`
  status          ClaudeTokenStatus @default(ACTIVE)
  lastValidatedAt DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt
}

// ── App models ────────────────────────────────────────────────────────────

model Project {
  id                String            @id @default(cuid())
  name              String
  defaultBrandKitId String?
  defaultBrandKit   BrandKit?         @relation("ProjectBrandKit", fields: [defaultBrandKitId], references: [id])
  defaultTone       String?
  isDeleted         Boolean           @default(false)
  deletedAt         DateTime?
  createdAt         DateTime          @default(now())
  campaigns         ProjectCampaign[]
}

model Campaign {
  id           String             @id @default(cuid())
  name         String
  brandKitId   String?
  brandKit     BrandKit?          @relation("CampaignBrandKit", fields: [brandKitId], references: [id])
  defaultTone  String?
  isDeleted    Boolean            @default(false)
  deletedAt    DateTime?
  createdAt    DateTime           @default(now())
  projects     ProjectCampaign[]
  briefs       Brief[]
  briefings    CampaignBriefing[]
  scheduledGenerations ScheduledGeneration[]
  documents    CampaignDocument[]
}

// A source document (strategy deck, product one-pager, …) handed in by an
// admin to ground the AI briefing assistant. The original file lives in the
// private campaign-docs MinIO bucket; parsedText is the extracted plain text
// (capped — `truncated` marks a cut) injected into briefing chat/enhance prompts.
model CampaignDocument {
  id          String   @id @default(cuid())
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id])
  name        String
  contentType String
  sizeBytes   Int
  objectKey   String
  parsedText  String   @db.Text
  truncated   Boolean  @default(false)
  createdBy   String
  createdAt   DateTime @default(now())

  @@index([campaignId])
}

// A planned post under a campaign: per-post brief specifics + a generation
// time. The scheduler worker claims due entries (FOR UPDATE SKIP LOCKED, same
// pattern as Post publishing), generates a Draft via the shared pipeline, then
// executes postAction. Retries with backoff on failure; FAILED is re-runnable.
model ScheduledGeneration {
  id          String               @id @default(cuid())
  campaignId  String
  campaign    Campaign             @relation(fields: [campaignId], references: [id])
  createdById String
  createdBy   User                 @relation(fields: [createdById], references: [id])
  // Per-post brief specifics (the campaign briefing carries the rest).
  topic       String
  description String?
  goal        String
  tone        String
  channels    Channel[]
  aspectRatio AspectRatio          @default(SQUARE)
  designMode  DesignMode
  templateId  String?
  template    BrandKitTemplate?    @relation("ScheduledGenerationTemplate", fields: [templateId], references: [id])
  // Scheduling
  generateAt  DateTime
  postAction  PostGenerationAction @default(HOLD)
  publishAt   DateTime?
  // Lifecycle — mirrors Post's H12 fields (nextRetryAt doubles as the RUNNING lease).
  status      GenerationStatus     @default(PENDING)
  errorReason String?
  retryCount  Int                  @default(0)
  nextRetryAt DateTime?
  // Results: the Brief is created on the first run attempt and reused across
  // retries; the Draft is set on success.
  briefId     String?
  brief       Brief?               @relation(fields: [briefId], references: [id])
  draftId     String?
  draft       Draft?               @relation(fields: [draftId], references: [id])
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @default(now()) @updatedAt

  @@index([status, generateAt])
  @@index([status, nextRetryAt])
  @@index([campaignId])
}

// Versioned free-text campaign briefing — the campaign-level "80% of the brief"
// injected into copy/design prompts for every post under the campaign, on top of
// the brand kit's voice prompt. Versioning mirrors BrandKitPrompt: exactly one
// isActive row per campaign; restore = re-activate an old version.
model CampaignBriefing {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id])
  content    String   @db.Text
  version    Int      @default(1)
  isActive   Boolean  @default(false)
  createdBy  String
  createdAt  DateTime @default(now())

  @@unique([campaignId, version])
}

model ProjectCampaign {
  projectId  String
  campaignId String
  project    Project  @relation(fields: [projectId], references: [id])
  campaign   Campaign @relation(fields: [campaignId], references: [id])

  @@id([projectId, campaignId])
}

model Brief {
  id                  String             @id @default(cuid())
  userId              String
  user                User               @relation(fields: [userId], references: [id])
  campaignId          String?
  campaign            Campaign?          @relation(fields: [campaignId], references: [id])
  brandKitId          String?
  brandKit            BrandKit?          @relation("BriefBrandKit", fields: [brandKitId], references: [id])
  topic               String
  description         String?
  goal                String
  tone                String
  channels            Channel[]
  aspectRatio         AspectRatio        @default(SQUARE)
  designMode          DesignMode
  copyProviderKey     String
  imageProviderKey    String?
  additionalImageUrl  String?
  briefImages         Json?
  referenceTemplateId String?
  referenceTemplate   BrandKitTemplate?  @relation("BriefReferenceTemplate", fields: [referenceTemplateId], references: [id])
  createdAt           DateTime           @default(now())
  drafts              Draft[]
  scheduledGenerations ScheduledGeneration[]

  @@index([userId])
  @@index([campaignId])
  @@index([brandKitId])
}

model Draft {
  id              String          @id @default(cuid())
  briefId         String
  brief           Brief           @relation(fields: [briefId], references: [id])
  copyText        String
  imageUrl        String?
  htmlContent     String?         @db.Text
  templateId      String?
  exportUrl       String?
  pendingConflict Json?
  // Which DraftRevision is currently active (revisionNumber, not id). The design
  // history is an append-only log of DraftRevision rows; this pointer says which
  // one the live htmlContent/exportUrl mirror, so reverting can move freely back
  // AND forward without losing states. Null for legacy rows created before this
  // field existed (treated as "latest revision").
  currentRevisionNumber Int?
  // Prompt revision that produced the current design (prompts/shared.ts
  // PROMPT_VERSION) — lets output quality be correlated with prompt changes.
  promptVersion   String?
  status          DraftStatus     @default(IN_PROGRESS)
  // Why the last generation attempt FAILED (model error, timeout, interruption).
  // Shown on the preview page's inline error card; cleared on a successful retry.
  failureReason   String?
  // In-flight draft action marker for the async action pattern (regenerate
  // copy/design, refine): set on atomic claim, cleared when the run settles.
  pendingAction   DraftAction?
  // Error from the last action run; cleared when the next action starts.
  pendingActionError String?
  createdAt       DateTime        @default(now())
  // @default(now()) keeps the added column valid for pre-existing rows
  updatedAt       DateTime        @default(now()) @updatedAt
  posts           Post[]
  revisions       DraftRevision[]
  scheduledGenerations ScheduledGeneration[]

  @@index([briefId])
}

model Post {
  id          String     @id @default(cuid())
  draftId     String
  draft       Draft      @relation(fields: [draftId], references: [id])
  userId      String
  user        User       @relation(fields: [userId], references: [id])
  channel     Channel
  status      PostStatus @default(PENDING)
  scheduledAt DateTime?
  publishedAt DateTime?
  platformId  String?
  errorReason String?
  retryCount  Int        @default(0)
  nextRetryAt DateTime?
  createdAt   DateTime   @default(now())
  // @default(now()) keeps the added column valid for pre-existing rows
  updatedAt   DateTime   @default(now()) @updatedAt

  @@index([status, scheduledAt])
  @@index([status, nextRetryAt])
  @@index([draftId])
  @@index([userId])
}

model BrandKit {
  id        String              @id @default(cuid())
  name      String
  colors    Json?
  fonts     Json?
  logoUrl   String?
  isDefault Boolean             @default(false)
  isDeleted Boolean             @default(false)
  deletedAt DateTime?
  createdAt DateTime            @default(now())
  prompts   BrandKitPrompt[]
  artifacts BrandKitArtifact[]
  templates BrandKitTemplate[]
  projects  Project[]           @relation("ProjectBrandKit")
  campaigns Campaign[]          @relation("CampaignBrandKit")
  briefs    Brief[]             @relation("BriefBrandKit")

  @@index([isDefault, isDeleted])
}

model BrandKitTemplate {
  id                 String   @id @default(cuid())
  brandKitId         String
  brandKit           BrandKit @relation(fields: [brandKitId], references: [id])
  name               String
  htmlTemplate       String   @db.Text
  aspectRatio        AspectRatio @default(SQUARE)
  createdAt          DateTime @default(now())
  referencedByBriefs Brief[]  @relation("BriefReferenceTemplate")
  scheduledGenerations ScheduledGeneration[] @relation("ScheduledGenerationTemplate")

  @@index([brandKitId])
}

model BrandKitPrompt {
  id         String   @id @default(cuid())
  brandKitId String
  brandKit   BrandKit @relation(fields: [brandKitId], references: [id])
  content    String
  version    Int      @default(1)
  isActive   Boolean  @default(false)
  createdBy  String
  createdAt  DateTime @default(now())

  @@unique([brandKitId, version])
}

model BrandKitArtifact {
  id         String       @id @default(cuid())
  brandKitId String
  brandKit   BrandKit     @relation(fields: [brandKitId], references: [id])
  type       ArtifactType
  name       String
  url        String
  feedToAI   Boolean      @default(false)
  // REFERENCE_DOC only: text extracted at upload time (PDF/DOCX/TXT/MD), fed
  // to the brand-kit assistant as grounding — mirrors CampaignDocument.
  parsedText String?      @db.Text
  truncated  Boolean      @default(false)
  createdAt  DateTime     @default(now())

  @@index([brandKitId])
}

model AvailableProvider {
  id              String       @id @default(cuid())
  slot            ProviderSlot
  providerKey     String
  providerName    String
  label           String
  keyPrefix       String
  encryptedApiKey String
  isEnabled       Boolean      @default(true)
  isDefault       Boolean      @default(false)
  createdAt       DateTime     @default(now())

  @@unique([slot, providerKey])
}

model ChannelToken {
  id                String   @id @default(cuid())
  channel           Channel  @unique
  encryptedToken    String
  encryptedMetadata String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model DraftRevision {
  id             String   @id @default(cuid())
  draftId        String
  draft          Draft    @relation(fields: [draftId], references: [id])
  revisionNumber Int
  instruction    String
  htmlSnapshot   String   @db.Text
  exportUrl      String?
  createdAt      DateTime @default(now())

  @@unique([draftId, revisionNumber])
}
