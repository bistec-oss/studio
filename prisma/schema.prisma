generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EDITOR
}

enum DesignMode {
  TEMPLATE
  GENERATE
}

enum DraftStatus {
  IN_PROGRESS
  EXPORTED
  PUBLISHED
  FAILED
}

enum Channel {
  INSTAGRAM
  LINKEDIN
}

enum PostStatus {
  PENDING
  SCHEDULED
  PUBLISHING
  PUBLISHED
  FAILED
  CANCELLED
}

enum ProviderSlot {
  COPY
  IMAGE
}

enum ArtifactType {
  LOGO
  FONT
  COLOR
  REFERENCE_IMAGE
  EXAMPLE_POST
  OTHER
}

// ── better-auth models ────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  // app-level role (managed server-side only — never writable via sign-up)
  role          Role      @default(EDITOR)
  // better-auth relations
  sessions      Session[]
  accounts      Account[]
  // app relations
  briefs        Brief[]
  posts         Post[]
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt
}

// ── App models ────────────────────────────────────────────────────────────

model Project {
  id                String            @id @default(cuid())
  name              String
  defaultBrandKitId String?
  defaultBrandKit   BrandKit?         @relation("ProjectBrandKit", fields: [defaultBrandKitId], references: [id])
  defaultTone       String?
  isDeleted         Boolean           @default(false)
  deletedAt         DateTime?
  createdAt         DateTime          @default(now())
  campaigns         ProjectCampaign[]
}

model Campaign {
  id           String            @id @default(cuid())
  name         String
  brandKitId   String?
  brandKit     BrandKit?         @relation("CampaignBrandKit", fields: [brandKitId], references: [id])
  defaultTone  String?
  isDeleted    Boolean           @default(false)
  deletedAt    DateTime?
  createdAt    DateTime          @default(now())
  projects     ProjectCampaign[]
  briefs       Brief[]
  drafts       CampaignDraft[]
}

model ProjectCampaign {
  projectId  String
  campaignId String
  project    Project  @relation(fields: [projectId], references: [id])
  campaign   Campaign @relation(fields: [campaignId], references: [id])

  @@id([projectId, campaignId])
}

model CampaignDraft {
  campaignId String
  draftId    String
  campaign   Campaign @relation(fields: [campaignId], references: [id])
  draft      Draft    @relation(fields: [draftId], references: [id])

  @@id([campaignId, draftId])
}

model Brief {
  id                  String             @id @default(cuid())
  userId              String
  user                User               @relation(fields: [userId], references: [id])
  campaignId          String?
  campaign            Campaign?          @relation(fields: [campaignId], references: [id])
  topic               String
  description         String?
  goal                String
  tone                String
  channels            String[]
  designMode          DesignMode
  copyProviderKey     String
  imageProviderKey    String?
  additionalImageUrl  String?
  briefImages         Json?
  referenceTemplateId String?
  referenceTemplate   BrandKitTemplate?  @relation("BriefReferenceTemplate", fields: [referenceTemplateId], references: [id])
  createdAt           DateTime           @default(now())
  drafts              Draft[]

  @@index([userId])
  @@index([campaignId])
}

model Draft {
  id              String          @id @default(cuid())
  briefId         String
  brief           Brief           @relation(fields: [briefId], references: [id])
  copyText        String
  imageUrl        String?
  htmlContent     String?         @db.Text
  templateId      String?
  exportUrl       String?
  pendingConflict Json?
  status          DraftStatus     @default(IN_PROGRESS)
  createdAt       DateTime        @default(now())
  posts           Post[]
  revisions       DraftRevision[]
  campaigns       CampaignDraft[]

  @@index([briefId])
}

model Post {
  id          String     @id @default(cuid())
  draftId     String
  draft       Draft      @relation(fields: [draftId], references: [id])
  userId      String
  user        User       @relation(fields: [userId], references: [id])
  channel     Channel
  status      PostStatus @default(PENDING)
  scheduledAt DateTime?
  publishedAt DateTime?
  platformId  String?
  errorReason String?
  retryCount  Int        @default(0)
  nextRetryAt DateTime?
  createdAt   DateTime   @default(now())

  @@index([status, scheduledAt])
  @@index([status, nextRetryAt])
  @@index([draftId])
  @@index([userId])
}

model BrandKit {
  id        String              @id @default(cuid())
  name      String
  colors    Json?
  fonts     Json?
  logoUrl   String?
  isDefault Boolean             @default(false)
  isDeleted Boolean             @default(false)
  deletedAt DateTime?
  createdAt DateTime            @default(now())
  prompts   BrandKitPrompt[]
  artifacts BrandKitArtifact[]
  templates BrandKitTemplate[]
  projects  Project[]           @relation("ProjectBrandKit")
  campaigns Campaign[]          @relation("CampaignBrandKit")

  @@index([isDefault, isDeleted])
}

model BrandKitTemplate {
  id                 String   @id @default(cuid())
  brandKitId         String
  brandKit           BrandKit @relation(fields: [brandKitId], references: [id])
  name               String
  htmlTemplate       String   @db.Text
  createdAt          DateTime @default(now())
  referencedByBriefs Brief[]  @relation("BriefReferenceTemplate")

  @@index([brandKitId])
}

model BrandKitPrompt {
  id         String   @id @default(cuid())
  brandKitId String
  brandKit   BrandKit @relation(fields: [brandKitId], references: [id])
  content    String
  version    Int      @default(1)
  isActive   Boolean  @default(false)
  createdBy  String
  createdAt  DateTime @default(now())

  @@unique([brandKitId, version])
}

model BrandKitArtifact {
  id         String       @id @default(cuid())
  brandKitId String
  brandKit   BrandKit     @relation(fields: [brandKitId], references: [id])
  type       ArtifactType
  name       String
  url        String
  feedToAI   Boolean      @default(false)
  createdAt  DateTime     @default(now())

  @@index([brandKitId])
}

model AvailableProvider {
  id              String       @id @default(cuid())
  slot            ProviderSlot
  providerKey     String
  providerName    String
  label           String
  keyPrefix       String
  encryptedApiKey String
  isEnabled       Boolean      @default(true)
  isDefault       Boolean      @default(false)
  createdAt       DateTime     @default(now())

  @@unique([slot, providerKey])
}

model ChannelToken {
  id                String   @id @default(cuid())
  channel           Channel  @unique
  encryptedToken    String
  encryptedMetadata String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model DraftRevision {
  id             String   @id @default(cuid())
  draftId        String
  draft          Draft    @relation(fields: [draftId], references: [id])
  revisionNumber Int
  instruction    String
  htmlSnapshot   String   @db.Text
  exportUrl      String?
  createdAt      DateTime @default(now())

  @@unique([draftId, revisionNumber])
}
