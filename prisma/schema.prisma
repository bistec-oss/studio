generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role { ADMIN EDITOR }
enum DesignMode { TEMPLATE GENERATE }
enum DraftStatus { IN_PROGRESS EXPORTED PUBLISHED FAILED }
enum Channel { INSTAGRAM LINKEDIN }
enum PostStatus { PENDING SCHEDULED PUBLISHED FAILED CANCELLED }
enum ProviderSlot { COPY IMAGE }
enum ArtifactType { LOGO FONT COLOR REFERENCE_IMAGE EXAMPLE_POST OTHER }

model User {
  id        String    @id @default(cuid())
  clerkId   String    @unique
  role      Role      @default(EDITOR)
  briefs    Brief[]
  posts     Post[]
  createdAt DateTime  @default(now())
}

model Project {
  id                String            @id @default(cuid())
  name              String
  defaultBrandKitId String?
  defaultBrandKit   BrandKit?         @relation("ProjectBrandKit", fields: [defaultBrandKitId], references: [id])
  defaultTone       String?
  isDeleted         Boolean           @default(false)
  deletedAt         DateTime?
  createdAt         DateTime          @default(now())
  campaigns         ProjectCampaign[]
}

model Campaign {
  id           String            @id @default(cuid())
  name         String
  brandKitId   String?
  brandKit     BrandKit?         @relation("CampaignBrandKit", fields: [brandKitId], references: [id])
  defaultTone  String?
  isDeleted    Boolean           @default(false)
  deletedAt    DateTime?
  createdAt    DateTime          @default(now())
  projects     ProjectCampaign[]
  briefs       Brief[]
  drafts       CampaignDraft[]
}

model ProjectCampaign {
  projectId  String
  campaignId String
  project    Project  @relation(fields: [projectId], references: [id])
  campaign   Campaign @relation(fields: [campaignId], references: [id])

  @@id([projectId, campaignId])
}

model CampaignDraft {
  campaignId String
  draftId    String
  campaign   Campaign @relation(fields: [campaignId], references: [id])
  draft      Draft    @relation(fields: [draftId], references: [id])

  @@id([campaignId, draftId])
}

model Brief {
  id                  String             @id @default(cuid())
  userId              String
  user                User               @relation(fields: [userId], references: [id])
  campaignId          String?
  campaign            Campaign?          @relation(fields: [campaignId], references: [id])
  topic               String
  description         String?
  goal                String
  tone                String
  channels            String[]
  designMode          DesignMode
  copyProviderKey     String
  imageProviderKey    String?
  additionalImageUrl  String?
  briefImages         Json?
  referenceTemplateId String?
  referenceTemplate   BrandKitTemplate?  @relation("BriefReferenceTemplate", fields: [referenceTemplateId], references: [id])
  createdAt           DateTime           @default(now())
  drafts              Draft[]
}

model Draft {
  id              String          @id @default(cuid())
  briefId         String
  brief           Brief           @relation(fields: [briefId], references: [id])
  copyText        String
  imageUrl        String?
  htmlContent     String?         @db.Text
  templateId      String?
  exportUrl       String?
  pendingConflict Json?
  status          DraftStatus     @default(IN_PROGRESS)
  createdAt       DateTime        @default(now())
  posts           Post[]
  revisions       DraftRevision[]
  campaigns       CampaignDraft[]
}

model Post {
  id          String     @id @default(cuid())
  draftId     String
  draft       Draft      @relation(fields: [draftId], references: [id])
  userId      String
  user        User       @relation(fields: [userId], references: [id])
  channel     Channel
  status      PostStatus @default(PENDING)
  scheduledAt DateTime?
  publishedAt DateTime?
  platformId  String?
  errorReason String?
  createdAt   DateTime   @default(now())
}

model BrandKit {
  id        String              @id @default(cuid())
  name      String
  colors    Json?
  fonts     Json?
  logoUrl   String?
  isDefault Boolean             @default(false)
  isDeleted Boolean             @default(false)
  deletedAt DateTime?
  createdAt DateTime            @default(now())
  prompts   BrandKitPrompt[]
  artifacts BrandKitArtifact[]
  templates BrandKitTemplate[]
  projects  Project[]           @relation("ProjectBrandKit")
  campaigns Campaign[]          @relation("CampaignBrandKit")
}

model BrandKitTemplate {
  id                 String   @id @default(cuid())
  brandKitId         String
  brandKit           BrandKit @relation(fields: [brandKitId], references: [id])
  name               String
  htmlTemplate       String   @db.Text
  createdAt          DateTime @default(now())
  referencedByBriefs Brief[]  @relation("BriefReferenceTemplate")
}

model BrandKitPrompt {
  id         String   @id @default(cuid())
  brandKitId String
  brandKit   BrandKit @relation(fields: [brandKitId], references: [id])
  content    String
  version    Int      @default(1)
  isActive   Boolean  @default(false)
  createdBy  String
  createdAt  DateTime @default(now())

  @@unique([brandKitId, version])
}

model BrandKitArtifact {
  id         String       @id @default(cuid())
  brandKitId String
  brandKit   BrandKit     @relation(fields: [brandKitId], references: [id])
  type       ArtifactType
  name       String
  url        String
  feedToAI   Boolean      @default(false)
  createdAt  DateTime     @default(now())
}

model AvailableProvider {
  id              String       @id @default(cuid())
  slot            ProviderSlot
  providerKey     String
  providerName    String
  label           String
  keyPrefix       String
  encryptedApiKey String
  isEnabled       Boolean      @default(true)
  isDefault       Boolean      @default(false)
  createdAt       DateTime     @default(now())

  @@unique([slot, providerKey])
}

model DraftRevision {
  id             String   @id @default(cuid())
  draftId        String
  draft          Draft    @relation(fields: [draftId], references: [id])
  revisionNumber Int
  instruction    String
  htmlSnapshot   String   @db.Text
  exportUrl      String?
  createdAt      DateTime @default(now())

  @@unique([draftId, revisionNumber])
}
