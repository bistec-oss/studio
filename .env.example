# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# better-auth (self-hosted — generate secret with: openssl rand -hex 32)
BETTER_AUTH_SECRET=your-32-byte-hex-secret
BETTER_AUTH_URL=http://localhost:3000

# Database (PostgreSQL via Docker Compose)
DATABASE_URL=postgresql://bistec:bistec@localhost:5432/bistec_studio

# MinIO (S3-compatible object storage via Docker Compose)
MINIO_ENDPOINT=http://localhost:9000
# Browser-facing base URL for PUBLIC objects (logos, brand artifacts, generated
# images, brief uploads). Defaults to MINIO_ENDPOINT — set this only when MinIO
# is reached internally on one host (e.g. http://minio:9000) but served to
# browsers from another (e.g. https://cdn.example.com). The IMAGES and BRANDKITS
# buckets are made public-read on startup; EXPORTS stays private (signed per read).
# MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_IMAGES=generated-images
MINIO_BUCKET_EXPORTS=exported-designs
MINIO_BUCKET_BRANDKITS=brand-kits

# Anthropic (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (https://platform.openai.com)
OPENAI_API_KEY=sk-...

# Design provider: "claude-html" (production) or "cli" (test mode — uses Claude Code CLI, no API key needed)
DESIGN_PROVIDER=claude-html

# Token encryption — generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=your-32-byte-hex-key

# Social APIs
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORGANIZATION_ID=
