# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# better-auth (self-hosted — generate secret with: openssl rand -hex 32)
# BETTER_AUTH_SECRET is REQUIRED (the app refuses to start with the placeholder in production).
BETTER_AUTH_SECRET=your-32-byte-hex-secret
BETTER_AUTH_URL=http://localhost:3000

# Database (PostgreSQL via Docker Compose)
DATABASE_URL=postgresql://bistec:bistec@localhost:5432/bistec_studio

# PostgreSQL container credentials (used by docker-compose.yml's postgres
# service). Keep them consistent with DATABASE_URL above.
POSTGRES_DB=bistec_studio
POSTGRES_USER=bistec
POSTGRES_PASSWORD=bistec

# MinIO (S3-compatible object storage via Docker Compose)
MINIO_ENDPOINT=http://localhost:9000
# Browser-facing base URL for PUBLIC objects (logos, brand artifacts, generated
# images, brief uploads). Defaults to MINIO_ENDPOINT — set this only when MinIO
# is reached internally on one host (e.g. http://minio:9000) but served to
# browsers from another (e.g. https://cdn.example.com). The IMAGES and BRANDKITS
# buckets are made public-read on startup; EXPORTS stays private (signed per read).
# MINIO_PUBLIC_ENDPOINT=http://localhost:9000
# App-side credentials. The "minioadmin" defaults are dev-only — production
# refuses to start with them (fail-closed check in src/lib/env.ts).
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
# MinIO server root credentials (used by docker-compose.yml's minio service).
# Keep them consistent with MINIO_ACCESS_KEY / MINIO_SECRET_KEY above.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
# Bucket names (optional — these are the defaults).
MINIO_BUCKET_IMAGES=generated-images
MINIO_BUCKET_EXPORTS=exported-designs
MINIO_BUCKET_BRANDKITS=brand-kits

# Anthropic (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (https://platform.openai.com)
OPENAI_API_KEY=sk-...

# Design provider: "claude-html" (production) or "cli" (test mode — uses Claude Code CLI, no API key needed)
DESIGN_PROVIDER=claude-html

# Path to the Claude Code CLI binary (optional — only needed when `claude` /
# `claude.cmd` is not on PATH). Used in CLI mode (DESIGN_PROVIDER=cli).
# CLAUDE_CLI_PATH=C:\Users\me\AppData\Roaming\npm\claude.cmd

# CLI-mode auth (DESIGN_PROVIDER=cli). Optional long-lived OAuth token from
# `claude setup-token` (~1-year lifetime; requires a Pro/Max/Team/Enterprise
# subscription) so headless `claude -p` spawns authenticate without the
# developer's interactive login. Unset = fall back to the logged-in session.
# Note: the spawn strips ANTHROPIC_API_KEY from the child env, so an API key in
# this file never hijacks CLI-mode auth — switch to the API path by setting
# DESIGN_PROVIDER=claude-html instead.
# CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...

# Model for CLI mode (DESIGN_PROVIDER=cli). Leave UNSET to use the per-path split
# (Path A / template fill → haiku, Path B / freeform → sonnet, matching the API
# path). Set it to force ONE model across every `claude -p` call — a global
# override, e.g. for testing: alias ("sonnet"/"opus"/"haiku") or a full model id.
# "default" omits --model and uses the costly account default (Opus) — avoid.
# CLAUDE_CLI_MODEL=sonnet

# CLI-mode diagnostics (DESIGN_PROVIDER=cli). On by default: logs each `claude -p`
# spawn, a liveness heartbeat, streamed stderr, and elapsed time — so a timeout is
# debuggable. Set to 0 to silence.
CLAUDE_CLI_DEBUG=1

# Puppeteer / headless Chromium (HTML → PNG rendering)
# Path to the Chromium/Chrome binary. Optional on Linux (common install paths
# are auto-detected); REQUIRED on Windows/macOS.
# PUPPETEER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
# Max concurrent renders (optional, default 2). Each render rasterizes at 2× DPI
# and is memory-heavy — raise with care.
# PUPPETEER_MAX_CONCURRENCY=2

# Token encryption — generate with: openssl rand -hex 32
# REQUIRED (the app refuses to start with the placeholder in production).
TOKEN_ENCRYPTION_KEY=your-32-byte-hex-key

# MCP server / external API access (optional — the MCP server and the ACP/MCP
# generate/publish capabilities stay locked without them)
# API key the local MCP server presents to the app.
# MCP_API_KEY=
# Comma-separated allow-lists of accepted API keys. Admin keys can call every
# capability; non-admin keys can call read / generate / publish only.
# BISTEC_API_KEYS=key1,key2
# BISTEC_ADMIN_API_KEYS=adminkey1

# Social APIs (optional env fallback — tokens registered in Admin → Settings →
# Social Channels take precedence and are stored encrypted in the DB)
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORGANIZATION_ID=

# Test seams (E2E suite only — dormant unless exactly "true"; NEVER set in
# production; see src/lib/testHooks.ts and docs/e2e-test-plan.md)
# MOCK_AI=true
# MOCK_PUPPETEER=true
# MOCK_SOCIAL=true
# MOCK_SOCIAL_FAIL=true
