#!/bin/sh
# husky pre-commit hook — blocks accidental .env commits
#
# Note: On Linux/Mac run `chmod +x .husky/pre-commit` after cloning.
# On Windows, husky handles the executable bit automatically.

# Check staged files for any .env file (exact match or .env.* variants, but NOT .env.example)
STAGED=$(git diff --cached --name-only)

if echo "$STAGED" | grep -qE '(^|/)\.env(\.[^e].*)?$'; then
  echo ""
  echo "❌  Commit blocked: a .env file is staged."
  echo "    Remove it with: git reset HEAD <file>"
  echo "    Never commit real secrets. Use .env.example for documentation."
  echo ""
  exit 1
fi

# Lint/format staged files (config in package.json "lint-staged")
npx lint-staged
